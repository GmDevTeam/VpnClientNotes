            int noteId;
            using (var db = new AppDbContext())
            {
                var note = new Note { UserId = adminId, Text = "Старый текст", CreatedAt = DateTime.Now };
                db.Notes.Add(note);
                db.SaveChanges();
                noteId = note.Id;
            }
            var command = new UpdateNoteCommand();
            command.Execute(new[] { noteId.ToString(), newText });
